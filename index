<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>English Verb Trainer 🇬🇧</title>
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&family=Fira+Mono:wght@400;700&display=swap" rel="stylesheet">
<style>
  :root {
    --bg:#0f0f1a;--card:#1a1a2e;--card2:#16213e;--accent:#e94560;--accent2:#0f3460;
    --green:#06d6a0;--yellow:#ffd166;--text:#e8e8f0;--muted:#888aaa;--border:#2a2a4a;
  }
  *{box-sizing:border-box;margin:0;padding:0;}
  body{font-family:'Nunito',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;}
  header{background:linear-gradient(135deg,#0f0f1a,#1a1a2e,#0f3460);padding:24px 20px 16px;text-align:center;border-bottom:2px solid var(--accent);}
  header h1{font-size:1.8rem;font-weight:900;}header h1 span{color:var(--accent);}
  header p{color:var(--muted);margin-top:4px;font-size:.9rem;}
  .tabs{display:flex;background:var(--card2);border-bottom:1px solid var(--border);overflow-x:auto;}
  .tab-btn{flex:1;min-width:120px;padding:13px 16px;background:none;border:none;color:var(--muted);font-family:'Nunito',sans-serif;font-size:.85rem;font-weight:700;cursor:pointer;border-bottom:3px solid transparent;white-space:nowrap;transition:all .2s;}
  .tab-btn:hover{color:var(--text);}
  .tab-btn.active{color:var(--accent);border-bottom-color:var(--accent);background:rgba(233,69,96,.05);}
  .section{display:none;padding:20px 16px;max-width:860px;margin:0 auto;}
  .section.active{display:block;}
  .stats-bar{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:16px;}
  .stat-chip{background:var(--card);border:1px solid var(--border);border-radius:20px;padding:5px 14px;font-size:.82rem;font-weight:700;}
  .stat-chip span{color:var(--accent);}
  .stat-chip.g span{color:var(--green);}
  .stat-chip.y span{color:var(--yellow);}
  .progress-wrap{background:var(--card2);border-radius:99px;height:7px;margin-bottom:18px;overflow:hidden;}
  .progress-bar{height:100%;background:linear-gradient(90deg,var(--accent),#ff6b9d);border-radius:99px;transition:width .4s;}
  .verb-card{background:var(--card);border:1px solid var(--border);border-radius:16px;padding:24px;margin-bottom:14px;animation:si .3s ease;}
  @keyframes si{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}
  .verb-label{font-size:.72rem;font-weight:800;color:var(--muted);letter-spacing:2px;text-transform:uppercase;margin-bottom:4px;}
  .verb-base{font-family:'Fira Mono',monospace;font-size:1.9rem;font-weight:700;color:var(--yellow);margin-bottom:3px;}
  .verb-meaning{color:var(--muted);font-size:.88rem;margin-bottom:18px;}
  .input-row{display:flex;gap:10px;flex-wrap:wrap;}
  .input-group{flex:1;min-width:150px;}
  .input-group label{display:block;font-size:.72rem;font-weight:800;color:var(--muted);letter-spacing:1px;text-transform:uppercase;margin-bottom:5px;}
  .verb-input{width:100%;background:var(--card2);border:2px solid var(--border);border-radius:9px;padding:9px 13px;color:var(--text);font-family:'Fira Mono',monospace;font-size:.95rem;font-weight:700;outline:none;transition:border-color .2s;}
  .verb-input:focus{border-color:var(--accent);}
  .verb-input.correct{border-color:var(--green);background:rgba(6,214,160,.08);}
  .verb-input.wrong{border-color:var(--accent);background:rgba(233,69,96,.08);}
  .verb-input:disabled{opacity:.7;}
  .feedback-row{display:flex;gap:8px;margin-top:10px;flex-wrap:wrap;}
  .answer-reveal{font-family:'Fira Mono',monospace;font-size:.82rem;padding:3px 10px;border-radius:5px;background:rgba(6,214,160,.12);color:var(--green);border:1px solid rgba(6,214,160,.3);}
  .btn{padding:10px 20px;border:none;border-radius:9px;font-family:'Nunito',sans-serif;font-size:.9rem;font-weight:800;cursor:pointer;transition:all .2s;}
  .btn-primary{background:var(--accent);color:#fff;}
  .btn-primary:hover{background:#ff6b9d;transform:translateY(-1px);}
  .btn-secondary{background:var(--card2);color:var(--text);border:1px solid var(--border);}
  .btn-secondary:hover{border-color:var(--accent);color:var(--accent);}
  .btn-row{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:18px;}
  .mode-selector{display:flex;gap:8px;margin-bottom:16px;flex-wrap:wrap;}
  .mode-btn{padding:7px 16px;background:var(--card2);border:2px solid var(--border);border-radius:7px;color:var(--muted);font-family:'Nunito',sans-serif;font-size:.82rem;font-weight:700;cursor:pointer;transition:all .2s;}
  .mode-btn.active,.mode-btn:hover{border-color:var(--accent);color:var(--accent);background:rgba(233,69,96,.07);}
  .result-box{background:var(--card);border:2px solid var(--green);border-radius:14px;padding:24px;text-align:center;margin-bottom:18px;animation:si .4s ease;display:none;}
  .result-box.show{display:block;}
  .result-score{font-size:2.8rem;font-weight:900;color:var(--green);}
  .result-msg{color:var(--muted);margin-top:5px;}

  /* ── IF CLAUSES ── */
  .grammar-box{background:var(--card2);border:1px solid var(--border);border-radius:11px;padding:18px;margin-bottom:20px;font-size:.86rem;}
  .grammar-box h3{font-size:.75rem;letter-spacing:2px;text-transform:uppercase;color:var(--muted);margin-bottom:10px;}
  .grammar-row{display:flex;gap:8px;align-items:flex-start;margin-bottom:7px;flex-wrap:wrap;}
  .grammar-badge{flex-shrink:0;font-size:.68rem;font-weight:800;padding:2px 8px;border-radius:4px;margin-top:2px;}
  .grammar-text{color:var(--muted);}
  .grammar-text code{font-family:'Fira Mono',monospace;color:var(--yellow);font-size:.8rem;}
  .type0{background:rgba(255,209,102,.15);color:var(--yellow);border:1px solid rgba(255,209,102,.3);}
  .type1{background:rgba(6,214,160,.12);color:var(--green);border:1px solid rgba(6,214,160,.3);}
  .type2{background:rgba(100,149,237,.12);color:#6495ED;border:1px solid rgba(100,149,237,.3);}
  .type3{background:rgba(233,69,96,.12);color:var(--accent);border:1px solid rgba(233,69,96,.3);}
  .if-card{background:var(--card);border:1px solid var(--border);border-radius:14px;padding:22px;margin-bottom:14px;animation:si .3s ease;}
  .if-type-badge{display:inline-block;font-size:.68rem;font-weight:800;letter-spacing:1.5px;text-transform:uppercase;padding:3px 10px;border-radius:20px;margin-bottom:9px;}
  .if-sentence{font-size:1rem;line-height:2;margin-bottom:10px;}
  .blank-input{display:inline-block;background:var(--card2);border:2px solid var(--border);border-radius:5px;padding:1px 9px;font-family:'Fira Mono',monospace;font-size:.9rem;font-weight:700;color:var(--text);min-width:90px;outline:none;transition:border-color .2s;vertical-align:middle;}
  .blank-input:focus{border-color:var(--accent);}
  .blank-input.correct{border-color:var(--green);color:var(--green);}
  .blank-input.wrong{border-color:var(--accent);color:var(--accent);}
  .if-hint{font-size:.78rem;color:var(--muted);margin-top:3px;}
  .if-answer-reveal{font-size:.83rem;color:var(--green);font-family:'Fira Mono',monospace;margin-top:6px;display:none;}

  /* ── REFERENCE TABLE ── */
  .search-input{width:100%;background:var(--card);border:2px solid var(--border);border-radius:9px;padding:11px 15px;color:var(--text);font-family:'Nunito',sans-serif;font-size:.95rem;margin-bottom:14px;outline:none;transition:border-color .2s;}
  .search-input:focus{border-color:var(--accent);}
  .ref-scroll{max-height:520px;overflow-y:auto;border-radius:11px;border:1px solid var(--border);}
  .ref-table{width:100%;border-collapse:collapse;font-size:.83rem;}
  .ref-table th{background:var(--accent2);color:var(--text);padding:9px 13px;text-align:left;font-size:.72rem;letter-spacing:1px;text-transform:uppercase;position:sticky;top:0;z-index:1;}
  .ref-table td{padding:8px 13px;border-bottom:1px solid var(--border);}
  .ref-table tr:hover td{background:rgba(255,255,255,.02);}
  .ref-table td:first-child{font-family:'Fira Mono',monospace;font-weight:700;color:var(--yellow);}
  .ref-table td:nth-child(2),.ref-table td:nth-child(3){font-family:'Fira Mono',monospace;}
  .ref-table td:last-child{color:var(--muted);}

  /* STATUS ICON in ref table */
  .ref-table td.status-cell{text-align:center;font-size:1rem;width:36px;}
  .status-icon-correct{color:var(--green);}
  .status-icon-wrong{color:var(--accent);}
  .status-icon-unseen{color:var(--border);}

  ::-webkit-scrollbar{width:5px;height:5px;}
  ::-webkit-scrollbar-track{background:var(--bg);}
  ::-webkit-scrollbar-thumb{background:var(--border);border-radius:99px;}
</style>
</head>
<body>

<header>
  <h1>English <span>Verb</span> Trainer 🇬🇧</h1>
  <p>Direkt aus dem Buch · Past Simple &amp; Participle · If Clauses</p>
</header>

<div class="tabs">
  <button class="tab-btn active" onclick="switchTab('verbs',this)">📝 Verben üben</button>
  <button class="tab-btn" onclick="switchTab('ifclauses',this)">🔀 If Clauses</button>
  <button class="tab-btn" onclick="switchTab('reference',this)">📖 Alle Verben</button>
</div>

<!-- VERBS -->
<div class="section active" id="tab-verbs">
  <div class="stats-bar">
    <div class="stat-chip">Verb <span id="v-cur">1</span> / <span id="v-tot">—</span></div>
    <div class="stat-chip g">✓ <span id="v-correct">0</span></div>
    <div class="stat-chip"><span id="v-wrong" style="color:var(--accent)">0</span> ✗</div>
    <div class="stat-chip y">🔥 <span id="v-streak">0</span></div>
  </div>
  <div class="progress-wrap"><div class="progress-bar" id="v-progress" style="width:0%"></div></div>
  <div class="mode-selector">
    <button class="mode-btn active" id="mode-both" onclick="setMode('both')">Beide Formen</button>
    <button class="mode-btn" id="mode-simple" onclick="setMode('simple')">Nur Past Simple</button>
    <button class="mode-btn" id="mode-participle" onclick="setMode('participle')">Nur Participle</button>
    <button class="mode-btn" id="mode-random" onclick="setMode('random')">Zufällig</button>
  </div>
  <div class="btn-row">
    <button class="btn btn-primary" onclick="checkVerb()">✓ Prüfen</button>
    <button class="btn btn-secondary" onclick="skipVerb()">→ Skip</button>
    <button class="btn btn-secondary" onclick="showHint()">💡 Tipp</button>
    <button class="btn btn-secondary" onclick="shuffleVerbs()">🔀 Mischen</button>
    <button class="btn btn-secondary" onclick="resetVerbs()">↺ Neustart</button>
  </div>
  <div class="result-box" id="v-result">
    <div class="result-score" id="v-result-score"></div>
    <div class="result-msg" id="v-result-msg"></div><br>
    <button class="btn btn-primary" onclick="resetVerbs()">↺ Nochmal</button>
  </div>
  <div class="verb-card" id="verb-card">
    <div class="verb-label">Infinitive</div>
    <div class="verb-base" id="v-base">—</div>
    <div class="verb-meaning" id="v-meaning">—</div>
    <div class="input-row">
      <div class="input-group" id="ig-simple">
        <label>Past Simple</label>
        <input class="verb-input" id="v-simple" placeholder="z.B. went" autocomplete="off" onkeydown="if(event.key==='Enter')checkVerb()">
      </div>
      <div class="input-group" id="ig-part">
        <label>Past Participle</label>
        <input class="verb-input" id="v-participle" placeholder="z.B. gone" autocomplete="off" onkeydown="if(event.key==='Enter')checkVerb()">
      </div>
    </div>
    <div class="feedback-row" id="v-feedback"></div>
  </div>
</div>

<!-- IF CLAUSES -->
<div class="section" id="tab-ifclauses">
  <div class="grammar-box">
    <h3>📚 Type 3 If Clauses – Formel</h3>
    <div class="grammar-row"><span class="grammar-badge type3">Formel</span><div class="grammar-text"><code>If + had + Past Participle, … would have + Past Participle</code></div></div>
    <div class="grammar-row"><span class="grammar-badge type3">Positiv</span><div class="grammar-text"><code>If she had studied, she would have passed.</code></div></div>
    <div class="grammar-row"><span class="grammar-badge type3">Negation If</span><div class="grammar-text"><code>If he hadn't forgotten, he would have passed.</code></div></div>
    <div class="grammar-row"><span class="grammar-badge type3">Negation Hauptsatz</span><div class="grammar-text"><code>If she had come, I wouldn't have been angry.</code></div></div>
    <div class="grammar-row" style="margin-top:6px"><span class="grammar-badge type3" style="background:rgba(233,69,96,.25)">Bedeutung</span><div class="grammar-text">Etwas in der Vergangenheit ist <b style="color:var(--text)">nicht passiert</b> — es ist eine unreale Situation. "Wenn ich gelernt hätte, hätte ich bestanden."</div></div>
  </div>
  <div class="stats-bar">
    <div class="stat-chip">Satz <span id="if-cur">1</span> / <span id="if-tot">30</span></div>
    <div class="stat-chip g">✓ <span id="if-correct">0</span></div>
    <div class="stat-chip"><span id="if-wrong" style="color:var(--accent)">0</span> ✗</div>
  </div>
  <div class="progress-wrap"><div class="progress-bar" id="if-progress" style="width:0%"></div></div>
  <div class="btn-row">
    <button class="btn btn-primary" onclick="checkIf()">✓ Prüfen</button>
    <button class="btn btn-secondary" onclick="nextIf()">→ Nächster</button>
    <button class="btn btn-secondary" onclick="showIfAnswer()">💡 Antwort</button>
    <button class="btn btn-secondary" onclick="resetIf()">↺ Neustart</button>
  </div>
  <div class="result-box" id="if-result">
    <div class="result-score" id="if-result-score"></div>
    <div class="result-msg" id="if-result-msg"></div><br>
    <button class="btn btn-primary" onclick="resetIf()">↺ Nochmal</button>
  </div>
  <div id="if-container"></div>
</div>

<!-- REFERENCE -->
<div class="section" id="tab-reference">
  <input class="search-input" placeholder="🔍 Verb suchen..." id="ref-search" oninput="filterRef()">
  <div style="font-size:.8rem;color:var(--muted);margin-bottom:10px;">
    <span style="color:var(--green)">✓</span> = richtig beantwortet &nbsp;
    <span style="color:var(--accent)">✗</span> = falsch beantwortet &nbsp;
    <span style="color:var(--border)">○</span> = noch nicht dran gewesen
  </div>
  <div class="ref-scroll">
    <table class="ref-table">
      <thead><tr><th></th><th>Infinitive</th><th>Past Simple</th><th>Past Participle</th><th>Bedeutung</th></tr></thead>
      <tbody id="ref-body"></tbody>
    </table>
  </div>
</div>

