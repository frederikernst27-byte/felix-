  ["wake","woke","woken","aufwachen"],
  ["wear","wore","worn","tragen"],
  ["win","won","won","gewinnen"],
  ["write","wrote","written","schreiben"],
];

// Deduplizieren nach Verb[0]
const seen = new Set();
const VERBS_CLEAN = VERBS.filter(v => {
  if(seen.has(v[0])){return false;} seen.add(v[0]); return true;
});

// ═══════════════════════════════════════════════
//  STATUS TRACKING: 'unseen' | 'correct' | 'wrong'
// ═══════════════════════════════════════════════
const verbStatus = {}; // key = verb[0]
VERBS_CLEAN.forEach(v => { verbStatus[v[0]] = 'unseen'; });

// ═══════════════════════════════════════════════
//  IF CLAUSES
// ═══════════════════════════════════════════════
const IF_SENTENCES = [
  {type:3,sentence:"If she ___ (study) harder, she ___ (pass) the test.",blanks:["had studied","would have passed"],hint:"If + had + PP → would have + PP",verb_hints:["study → had studied","pass → would have passed"]},
  {type:3,sentence:"If he ___ (take) the bus, he ___ (arrive) on time.",blanks:["had taken","would have arrived"],hint:"If + had + PP → would have + PP",verb_hints:["take → had taken","arrive → would have arrived"]},
  {type:3,sentence:"If they ___ (not forget) the tickets, they ___ (see) the concert.",blanks:["hadn't forgotten","would have seen"],hint:"Negation: hadn't + PP → would have + PP",verb_hints:["not forget → hadn't forgotten","see → would have seen"]},
  {type:3,sentence:"If I ___ (know) about the party, I ___ (come).",blanks:["had known","would have come"],hint:"If + had + PP → would have + PP",verb_hints:["know → had known","come → would have come"]},
  {type:3,sentence:"If she ___ (eat) breakfast, she ___ (not feel) so tired.",blanks:["had eaten","wouldn't have felt"],hint:"Negation: wouldn't have + PP",verb_hints:["eat → had eaten","not feel → wouldn't have felt"]},
  {type:3,sentence:"If we ___ (leave) earlier, we ___ (catch) the flight.",blanks:["had left","would have caught"],hint:"If + had + PP → would have + PP",verb_hints:["leave → had left","catch → would have caught"]},
  {type:3,sentence:"If he ___ (save) his money, he ___ (buy) a car.",blanks:["had saved","would have bought"],hint:"If + had + PP → would have + PP",verb_hints:["save → had saved","buy → would have bought"]},
  {type:3,sentence:"If you ___ (tell) me the truth, I ___ (not be) angry.",blanks:["had told","wouldn't have been"],hint:"Negation: wouldn't have + PP",verb_hints:["tell → had told","not be → wouldn't have been"]},
  {type:3,sentence:"If they ___ (practise) more, they ___ (win) the match.",blanks:["had practised","would have won"],hint:"If + had + PP → would have + PP",verb_hints:["practise → had practised","win → would have won"]},
  {type:3,sentence:"If I ___ (wake up) earlier, I ___ (not miss) the train.",blanks:["had woken up","wouldn't have missed"],hint:"Negation: wouldn't have + PP",verb_hints:["wake up → had woken up","not miss → wouldn't have missed"]},
  {type:3,sentence:"If she ___ (bring) her umbrella, she ___ (not get) wet.",blanks:["had brought","wouldn't have got"],hint:"Negation: wouldn't have + PP",verb_hints:["bring → had brought","not get → wouldn't have got"]},
  {type:3,sentence:"If he ___ (read) the instructions, he ___ (build) it correctly.",blanks:["had read","would have built"],hint:"If + had + PP → would have + PP",verb_hints:["read → had read","build → would have built"]},
  {type:3,sentence:"If we ___ (choose) a different route, we ___ (avoid) the traffic.",blanks:["had chosen","would have avoided"],hint:"If + had + PP → would have + PP",verb_hints:["choose → had chosen","avoid → would have avoided"]},
  {type:3,sentence:"If you ___ (speak) more slowly, I ___ (understand) you.",blanks:["had spoken","would have understood"],hint:"If + had + PP → would have + PP",verb_hints:["speak → had spoken","understand → would have understood"]},
  {type:3,sentence:"If they ___ (not fight), their friendship ___ (not break).",blanks:["hadn't fought","wouldn't have broken"],hint:"Negation auf beiden Seiten",verb_hints:["not fight → hadn't fought","not break → wouldn't have broken"]},
  {type:3,sentence:"If I ___ (drink) more water, I ___ (not feel) so bad.",blanks:["had drunk","wouldn't have felt"],hint:"Negation: wouldn't have + PP",verb_hints:["drink → had drunk","not feel → wouldn't have felt"]},
  {type:3,sentence:"If he ___ (write) down the homework, he ___ (not forget) it.",blanks:["had written","wouldn't have forgotten"],hint:"Negation: wouldn't have + PP",verb_hints:["write → had written","not forget → wouldn't have forgotten"]},
  {type:3,sentence:"If she ___ (win) the competition, she ___ (go) to the finals.",blanks:["had won","would have gone"],hint:"If + had + PP → would have + PP",verb_hints:["win → had won","go → would have gone"]},
  {type:3,sentence:"If we ___ (not lose) the map, we ___ (find) the way.",blanks:["hadn't lost","would have found"],hint:"Negation: hadn't + PP → would have + PP",verb_hints:["not lose → hadn't lost","find → would have found"]},
  {type:3,sentence:"If I ___ (see) him, I ___ (give) him your message.",blanks:["had seen","would have given"],hint:"If + had + PP → would have + PP",verb_hints:["see → had seen","give → would have given"]},
  {type:3,sentence:"If she ___ (not fall asleep), she ___ (hear) the alarm.",blanks:["hadn't fallen asleep","would have heard"],hint:"Negation: hadn't + PP → would have + PP",verb_hints:["not fall → hadn't fallen asleep","hear → would have heard"]},
  {type:3,sentence:"If he ___ (run) faster, he ___ (catch) the bus.",blanks:["had run","would have caught"],hint:"If + had + PP → would have + PP",verb_hints:["run → had run","catch → would have caught"]},
  {type:3,sentence:"If they ___ (buy) the tickets earlier, it ___ (be) cheaper.",blanks:["had bought","would have been"],hint:"If + had + PP → would have + PP",verb_hints:["buy → had bought","be → would have been"]},
  {type:3,sentence:"If I ___ (not spend) all my money, I ___ (afford) the trip.",blanks:["hadn't spent","would have afforded"],hint:"Negation: hadn't + PP → would have + PP",verb_hints:["not spend → hadn't spent","afford → would have afforded"]},
  {type:3,sentence:"If he ___ (think) before speaking, he ___ (not hurt) her feelings.",blanks:["had thought","wouldn't have hurt"],hint:"Negation: wouldn't have + PP",verb_hints:["think → had thought","not hurt → wouldn't have hurt"]},
  {type:3,sentence:"If she ___ (make) a reservation, she ___ (get) a table.",blanks:["had made","would have got"],hint:"If + had + PP → would have + PP",verb_hints:["make → had made","get → would have got"]},
  {type:3,sentence:"If we ___ (meet) earlier, we ___ (become) friends sooner.",blanks:["had met","would have become"],hint:"If + had + PP → would have + PP",verb_hints:["meet → had met","become → would have become"]},
  {type:3,sentence:"If he ___ (not break) the window, his parents ___ (not find out).",blanks:["hadn't broken","wouldn't have found out"],hint:"Negation auf beiden Seiten",verb_hints:["not break → hadn't broken","not find out → wouldn't have found out"]},
  {type:3,sentence:"If I ___ (sleep) enough, I ___ (do) better on the test.",blanks:["had slept","would have done"],hint:"If + had + PP → would have + PP",verb_hints:["sleep → had slept","do → would have done"]},
  {type:3,sentence:"If she ___ (send) the email in time, he ___ (receive) the news.",blanks:["had sent","would have received"],hint:"If + had + PP → would have + PP",verb_hints:["send → had sent","receive → would have received"]},
];

// ═══════════════════════════════════════════════
//  STATE
// ═══════════════════════════════════════════════
let verbIdx=0, vCorrect=0, vWrong=0, vStreak=0;
let verbOrder=[...Array(VERBS_CLEAN.length).keys()];
let mode='both';
let ifIdx=0,ifCorrect=0,ifWrong=0;
let hintShown=false;

// ═══════════════════════════════════════════════
//  TABS
// ═══════════════════════════════════════════════
function switchTab(t,btn){
  document.querySelectorAll('.section').forEach(s=>s.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b=>b.classList.remove('active'));
  document.getElementById('tab-'+t).classList.add('active');
  btn.classList.add('active');
  if(t==='reference')buildRef();
  if(t==='ifclauses')renderIf();
}

// ═══════════════════════════════════════════════
//  VERB QUIZ
// ═══════════════════════════════════════════════
function setMode(m){
  mode=m;
  document.querySelectorAll('.mode-btn').forEach(b=>b.classList.remove('active'));
  document.getElementById('mode-'+m).classList.add('active');
  renderVerb();
}

function renderVerb(){
  document.getElementById('v-tot').textContent=VERBS_CLEAN.length;
  if(verbIdx>=VERBS_CLEAN.length){showVerbResult();return;}
  const v=VERBS_CLEAN[verbOrder[verbIdx]];
  document.getElementById('v-base').textContent=v[0];
  document.getElementById('v-meaning').textContent='🇩🇪 '+v[3];
  document.getElementById('v-feedback').innerHTML='';
  hintShown=false;
  const si=document.getElementById('v-simple');
  const pi=document.getElementById('v-participle');
  si.value='';pi.value='';
  si.className='verb-input';pi.className='verb-input';
  si.disabled=false;pi.disabled=false;
  const m=mode==='random'?(Math.random()>.5?'simple':'participle'):mode;
  document.getElementById('ig-simple').style.display=(m==='participle')?'none':'';
  document.getElementById('ig-part').style.display=(m==='simple')?'none':'';
  setTimeout(()=>{(m==='participle'?pi:si).focus();},50);
  document.getElementById('v-cur').textContent=verbIdx+1;
  document.getElementById('v-progress').style.width=(verbIdx/VERBS_CLEAN.length*100)+'%';
  document.getElementById('v-result').classList.remove('show');
  document.getElementById('verb-card').style.display='';
}

function checkVerb(){
  const v=VERBS_CLEAN[verbOrder[verbIdx]];
  const si=document.getElementById('v-simple');
  const pi=document.getElementById('v-participle');
  const fb=document.getElementById('v-feedback');
  fb.innerHTML='';
  let allOk=true;

  function chk(inp,correct,label){
    if(inp.closest('.input-group').style.display==='none')return;
    const ok=correct.toLowerCase().split('/').map(s=>s.trim());
    const val=inp.value.trim().toLowerCase();
    if(!val)return;
    if(ok.some(a=>a===val)){inp.className='verb-input correct';}
    else{inp.className='verb-input wrong';allOk=false;
      const d=document.createElement('div');d.className='answer-reveal';
      d.textContent=label+': '+correct;fb.appendChild(d);}
    inp.disabled=true;
  }
  chk(si,v[1],'Past Simple');
  chk(pi,v[2],'Past Participle');

  const hasSimple=document.getElementById('ig-simple').style.display!=='none';
  const hasPart=document.getElementById('ig-part').style.display!=='none';
  if(hasSimple&&!si.value.trim())return;
  if(hasPart&&!pi.value.trim())return;

  // Update status
  if(verbStatus[v[0]]==='unseen'||verbStatus[v[0]]==='wrong'){
    verbStatus[v[0]]=allOk?'correct':'wrong';
  }

  if(allOk){
    vCorrect++;vStreak++;
    document.getElementById('v-correct').textContent=vCorrect;
    document.getElementById('v-streak').textContent=vStreak;
    setTimeout(()=>{verbIdx++;renderVerb();},800);
  }else{
    vWrong++;vStreak=0;
    document.getElementById('v-wrong').textContent=vWrong;
    document.getElementById('v-streak').textContent=vStreak;
    setTimeout(()=>{verbIdx++;renderVerb();},2200);
  }
}

function skipVerb(){verbIdx++;renderVerb();}

function showHint(){
  if(hintShown)return;
  const v=VERBS_CLEAN[verbOrder[verbIdx]];
  const fb=document.getElementById('v-feedback');
  const h=document.createElement('div');h.className='answer-reveal';
  h.textContent='💡 '+v[0].charAt(0).toUpperCase()+v[0].slice(1)+' → '+v[1].charAt(0)+'...';
  fb.appendChild(h);hintShown=true;
}

function shuffleVerbs(){
  verbOrder=verbOrder.sort(()=>Math.random()-.5);
  verbIdx=0;vCorrect=0;vWrong=0;vStreak=0;
  updateVStats();renderVerb();
}

function resetVerbs(){
  verbOrder=[...Array(VERBS_CLEAN.length).keys()];
  verbIdx=0;vCorrect=0;vWrong=0;vStreak=0;
  VERBS_CLEAN.forEach(v=>{verbStatus[v[0]]='unseen';});
  updateVStats();renderVerb();
}

function updateVStats(){
  document.getElementById('v-correct').textContent=vCorrect;
  document.getElementById('v-wrong').textContent=vWrong;
  document.getElementById('v-streak').textContent=vStreak;
}

function showVerbResult(){
  const total=vCorrect+vWrong;
  const pct=total?Math.round(vCorrect/total*100):0;
  document.getElementById('v-result-score').textContent=pct+'%';
  const msg=pct>=90?'🏆 Perfekt! Klausur kein Problem!':pct>=70?'👍 Gut! Noch ein Durchgang.':'💪 Weitermachen!';
  document.getElementById('v-result-msg').textContent=vCorrect+' von '+total+' richtig. '+msg;
  document.getElementById('v-result').classList.add('show');
  document.getElementById('verb-card').style.display='none';
}

// ═══════════════════════════════════════════════
//  IF CLAUSES
// ═══════════════════════════════════════════════
function renderIf(){
  const c=document.getElementById('if-container');c.innerHTML='';
  if(ifIdx>=IF_SENTENCES.length){showIfResult();return;}
  const s=IF_SENTENCES[ifIdx];
  const card=document.createElement('div');card.className='if-card';
  const tl=['Type 0 – Allgemein','Type 1 – Reale Zukunft','Type 2 – Hypothetisch','Type 3 – Vergangenheit'];
  const b=document.createElement('div');b.className='if-type-badge type'+s.type;b.textContent=tl[s.type];
  card.appendChild(b);
  const parts=s.sentence.split('___');
  const sent=document.createElement('div');sent.className='if-sentence';
  parts.forEach((p,i)=>{
    sent.appendChild(document.createTextNode(p));
    if(i<s.blanks.length){
      const inp=document.createElement('input');inp.className='blank-input';
      inp.id='blank-'+i;inp.placeholder='...';inp.setAttribute('data-answer',s.blanks[i]);
      inp.autocomplete='off';inp.addEventListener('keydown',e=>{if(e.key==='Enter')checkIf();});
      sent.appendChild(inp);
    }
  });
  card.appendChild(sent);
  const hd=document.createElement('div');hd.className='if-hint';hd.textContent='💡 '+s.hint;card.appendChild(hd);
  s.verb_hints.forEach(vh=>{
    const vd=document.createElement('div');vd.className='if-hint';
    vd.style.cssText='font-family:"Fira Mono",monospace;color:var(--yellow);';vd.textContent='📌 '+vh;card.appendChild(vd);
  });
  const ad=document.createElement('div');ad.className='if-answer-reveal';ad.id='if-ans';
  ad.textContent='✅ Lösung: '+s.blanks.join(' | ');card.appendChild(ad);
  c.appendChild(card);
  document.getElementById('if-cur').textContent=ifIdx+1;
  document.getElementById('if-result').classList.remove('show');
  document.getElementById('if-progress').style.width=(ifIdx/IF_SENTENCES.length*100)+'%';
  setTimeout(()=>{const f=document.getElementById('blank-0');if(f)f.focus();},50);
}

function checkIf(){
  const s=IF_SENTENCES[ifIdx];let allOk=true;
  s.blanks.forEach((ans,i)=>{
    const inp=document.getElementById('blank-'+i);if(!inp)return;
    const val=inp.value.trim().toLowerCase();
    const ok=ans.toLowerCase().split('/').map(a=>a.trim());
    if(ok.some(a=>a===val)){inp.className='blank-input correct';}
    else{inp.className='blank-input wrong';allOk=false;}
    inp.disabled=true;
  });
  document.getElementById('if-ans').style.display='block';
  if(allOk){ifCorrect++;document.getElementById('if-correct').textContent=ifCorrect;
    setTimeout(()=>{ifIdx++;if(ifIdx>=IF_SENTENCES.length)showIfResult();else renderIf();},1200);
  }else{ifWrong++;document.getElementById('if-wrong').textContent=ifWrong;
    setTimeout(()=>{ifIdx++;if(ifIdx>=IF_SENTENCES.length)showIfResult();else renderIf();},2500);}
}

function nextIf(){ifIdx++;if(ifIdx>=IF_SENTENCES.length)showIfResult();else renderIf();}
function showIfAnswer(){document.getElementById('if-ans').style.display='block';}
function resetIf(){
  ifIdx=0;ifCorrect=0;ifWrong=0;
  document.getElementById('if-correct').textContent=0;
  document.getElementById('if-wrong').textContent=0;
  document.getElementById('if-result').classList.remove('show');
  renderIf();
}
function showIfResult(){
  const pct=Math.round(ifCorrect/IF_SENTENCES.length*100);
  document.getElementById('if-result-score').textContent=pct+'%';
  const msg=pct>=90?'🏆 Perfekt!':pct>=60?'👍 Gut gemacht!':'💪 Nochmal versuchen!';
  document.getElementById('if-result-msg').textContent=ifCorrect+' von '+IF_SENTENCES.length+' richtig. '+msg;
  document.getElementById('if-result').classList.add('show');
  document.getElementById('if-container').innerHTML='';
}

// ═══════════════════════════════════════════════
//  REFERENCE TABLE WITH STATUS ICONS
// ═══════════════════════════════════════════════
function buildRef(){filterRef();}

function filterRef(){
  const q=(document.getElementById('ref-search')?.value||'').toLowerCase();
  const tbody=document.getElementById('ref-body');
  tbody.innerHTML='';
  VERBS_CLEAN
    .filter(v=>!q||v[0].includes(q)||v[1].includes(q)||v[2].includes(q)||v[3].toLowerCase().includes(q))
    .forEach(v=>{
      const st=verbStatus[v[0]]||'unseen';
      let icon,cls;
      if(st==='correct'){icon='✓';cls='status-icon-correct';}
      else if(st==='wrong'){icon='✗';cls='status-icon-wrong';}
      else{icon='○';cls='status-icon-unseen';}
      const tr=document.createElement('tr');
      tr.innerHTML=`<td class="status-cell"><span class="${cls}">${icon}</span></td>
        <td>${v[0]}</td><td>${v[1]}</td><td>${v[2]}</td>
        <td>${v[3]}</td>`;
      tbody.appendChild(tr);
    });
}

// INIT
renderVerb();
</script>
